Options -Indexes
ErrorDocument 404 /404.php
php_value auto_prepend_file "/home/bitrix/www/bitrix/modules/security/tools/start.php"

<IfModule mod_php5.c>
	allow_url_fopen = Off
	#php_flag allow_call_time_pass_reference 1
	#php_flag session.use_trans_sid off

	#php_value display_errors 1
	#php_value mbstring.internal_encoding UTF-8
</IfModule>

<IfModule mod_rewrite.c>
	Options +FollowSymLinks
	RewriteEngine On
	
	# Вырезаем код Blog из url
	# RewriteCond %{REQUEST_URI} ^/blog/Blog/(.*)$ 
	# RewriteRule ^(.*)$ /blog/%1 [R=301,L] 
	
	RewriteRule ^catalog/analizy_po_tipu/allergodiagnostika_immunocap/?$ https://tafimed.ru/services/allergologicheskie-issledovaniya/allergologicheskie-issledovaniya/ [R=301,L]
	RewriteRule ^catalog/analizy_po_tipu/infektsii/kleshchevye_infektsii/?$ https://tafimed.ru/services/kleshchevye-infektsii/kleshchevye-infektsii/ [R=301,L]

	  RewriteCond %{THE_REQUEST} !bitrix/admin/	
	  RewriteCond %{REQUEST_URI} !\?
      RewriteCond %{REQUEST_URI} !\&
      RewriteCond %{REQUEST_URI} !\=
      RewriteCond %{REQUEST_URI} !\.
      RewriteCond %{REQUEST_URI} !\/$
      RewriteRule ^(.*[^\/])$ /$1/ [R=301,L] 

      RewriteCond %{THE_REQUEST} !bitrix/admin/	
	RewriteCond %{THE_REQUEST} //
	  RewriteRule .* /$0 [R=301,L]
	  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/

RewriteRule ^index\.php$ https://tafimed.ru/ [R=301,L]
	RewriteCond %{SERVER_PORT} !^443$
	RewriteRule .* https://%{SERVER_NAME}%{REQUEST_URI} [R,L]
	  
	#RewriteCond %{HTTP_HOST} ^www\.(.*)$
	#RewriteRule ^(.*)$ http://%1/$1 [L,R=301]
	  
	RewriteCond %{HTTP_HOST} ^www\.tafimed\.ru [NC]
	RewriteRule ^(.*)$ https://tafimed.ru/$1 [R=301,L]

	RewriteCond %{THE_REQUEST} /(.*)index.php.*$
	RewriteCond %{THE_REQUEST} !bitrix/admin/
	RewriteRule .* /%1 [R=301,L]

	RewriteRule ^artem/(.*|)$ /$1 [L,NC]   
    RewriteRule ^ussurisk/(.*|)$ /$1 [L,NC]   
    RewriteRule ^bolshoykamen/(.*|)$ /$1 [L,NC]   
    RewriteRule ^nahodka/(.*|)$ /$1 [L,NC]   
    RewriteRule ^slavyanka/(.*|)$ /$1 [L,NC]   
    RewriteRule ^arsenev/(.*|)$ /$1 [L,NC]   
    RewriteRule ^birobidzhan/(.*|)$ /$1 [L,NC]   
    RewriteRule ^habarovsk/(.*|)$ /$1 [L,NC]   

	RewriteCond %{REQUEST_URI} ^/robots.txt$
	RewriteRule ^(.*)$ /multidomain_robots.php [L]
	
		
	RewriteCond %{REQUEST_URI} ^/sitemap.xml$
	RewriteRule ^(.*)$ /multidomain_sitemap.php [L]		
	
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-l
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !/bitrix/urlrewrite.php$
	RewriteRule ^(.*)$ /bitrix/urlrewrite.php [L]
	RewriteRule .* - [E=REMOTE_USER:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_dir.c>
	DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_expires.c>
	ExpiresActive on
	ExpiresByType image/jpeg "access plus 3 day"
	ExpiresByType image/gif "access plus 3 day"
</IfModule>
<IfModule headers_module>
Redirect 301 /catalog/analizy_po_tipu/check_up_kompleksnye_programmy/  /landings/checkup/
 RewriteRule ^contacts/?$ https://tafimed.ru/contacts/stores/ [R=301,L]
Header set Content-Security-Policy "frame-ancestors 'self' https://tafi.bitrix24.ru" 
</IfModule>
Header edit Set-Cookie ^(.*)$ $1;HttpOnly;Secure;SameSite=None