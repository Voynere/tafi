### Bitrix template

# Исключаем настройки PHPStorm, мы в нём работаем
/.idea/
/.vscode/

# Исключаем из гита битриксовые файлы
/bitrix/*
/bitrix/templates/landing24/

# Но не папку с шаблоном и не небитриксовые компоненты
!/bitrix/templates
!/bitrix/components
/bitrix/components/bitrix

#Exclude bitrix gadgets
!/bitrix/gadgets
/bitrix/gadgets/bitrix


!/bitrix/php_interface/

# Исключаем конфиги базы
/bitrix/php_interface/dbconn.php

# Исключаем дефолтную директорию медиафайлов
/upload/*
/product_files/*

/111111_logs/

# различные системные папки и файлы хостингов и операционных систем
/cgi-bin/
/awstats/
/webstat/
.DS_Store
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# архивы, включая многотомные
*.zip
*.zip*
*.tar
*.tar*
*.enc
*.enc*
*.gz
*.gz*
*.tgz
*.tgz*
*.sql
*.rar
.hg
